<Window x:Class="FaaTools.RevitAddin.Wpf.CompletionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FAA Tools"
        Height="160"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock x:Name="MessageText"
               Grid.Row="0"
               TextWrapping="Wrap"
               VerticalAlignment="Top"
               Margin="0,0,0,14"/>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button x:Name="OpenFileButton" Content="Open File" Width="96" Height="28" Margin="0,0,8,0" Click="OnOpenFile"/>
      <Button x:Name="OpenFolderButton" Content="Open Folder" Width="96" Height="28" Margin="0,0,8,0" Click="OnOpenFolder"/>
      <Button x:Name="CopyPathButton" Content="Copy Path" Width="96" Height="28" Margin="0,0,8,0" Click="OnCopyPath"/>
      <Button Content="Done" Width="80" Height="28" Click="OnDone" IsDefault="True"/>
    </StackPanel>
  </Grid>
</Window>
