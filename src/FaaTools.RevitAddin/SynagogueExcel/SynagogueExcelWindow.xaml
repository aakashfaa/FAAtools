<Window x:Class="FaaTools.RevitAddin.SynagogueExcel.SynagogueExcelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Synagogue Excel"
        Height="320"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Creates a starter Synagogue Master Program workbook for this project. Review the values below before generating."
               TextWrapping="Wrap"
               FontSize="13"
               Margin="0,0,0,16"/>

    <StackPanel x:Name="FieldsPanel" Grid.Row="1" VerticalAlignment="Top"/>

    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,16,0,0">
      <Button Content="Cancel" Width="90" Height="28" Margin="0,0,8,0" Click="OnCancel"/>
      <Button Content="Generate" Width="90" Height="28" Click="OnGenerate" IsDefault="True"/>
    </StackPanel>
  </Grid>
</Window>
