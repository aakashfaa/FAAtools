<Window x:Class="FaaTools.RevitAddin.Synagogue.SynagogueWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Synagogue Space Programming"
        Height="470"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="Synagogue Space Programming"
               FontSize="18"
               FontWeight="Bold"
               Margin="0,0,0,14"/>

    <Grid Grid.Row="1">
      <Grid x:Name="firstStepPanel">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                   Text="Step 1: Select the synagogue master program workbook."
                   TextWrapping="Wrap"
                   Margin="0,0,0,14"/>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Excel file:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 x:Name="fileText"
                 Height="26"
                 Margin="0,0,10,0"/>
        <Button Grid.Row="1" Grid.Column="2"
                Content="Browse..."
                Width="88"
                Height="26"
                Click="OnBrowse"/>
      </Grid>

      <Grid x:Name="secondStepPanel">
        <!--
          10 rows (0-9), one per content row below, all Auto-sized - the original pyRevit
          window.xaml only defined 9 rows but used Grid.Row="9" for recommendedSnapshotCheck,
          an off-by-one that left it outside the defined grid; fixed here.
        -->
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="150"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="Step 2: Choose the space allocation and the PDF pages to create."
                   TextWrapping="Wrap"
                   Margin="0,0,0,14"/>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Project:"
                   VerticalAlignment="Top"
                   Margin="0,0,10,10"/>
        <TextBlock Grid.Row="1" Grid.Column="1"
                   x:Name="projectNameValue"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Space Allocation:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,10"/>
        <ComboBox Grid.Row="2" Grid.Column="1"
                  x:Name="spaceAllocationCombo"
                  Height="26"
                  Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                   Text="Export:"
                   FontWeight="SemiBold"
                   Margin="0,6,0,10"/>

        <TextBlock Grid.Row="4" Grid.Column="0"
                   Text="Output:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,10"/>
        <ComboBox Grid.Row="4" Grid.Column="1"
                  x:Name="exportCombo"
                  Height="26"
                  Margin="0,0,0,10"/>

        <TextBlock Grid.Row="5" Grid.Column="0"
                   x:Name="revitOutputLabel"
                   Text="Revit output:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,10"
                   Visibility="Collapsed"/>
        <ComboBox Grid.Row="5" Grid.Column="1"
                  x:Name="revitOutputCombo"
                  Height="26"
                  Margin="0,0,0,10"
                  Visibility="Collapsed"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="pdfOptionsLabel"
                   Text="Include in PDF:"
                   FontWeight="SemiBold"
                   Margin="0,6,0,10"/>

        <CheckBox Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="distributionCheck"
                  Content="Space Distribution summary (%)"
                  Margin="0,0,0,8"/>
        <CheckBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="existingSnapshotCheck"
                  Content="Existing Building Snapshot"
                  Margin="0,0,0,8"/>
        <CheckBox Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                  x:Name="recommendedSnapshotCheck"
                  Content="Recommended Building Snapshot"/>
      </Grid>
    </Grid>

    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,18,0,0">
      <Button x:Name="backButton"
              Content="Back"
              Width="90"
              Height="28"
              Margin="0,0,10,0"
              Click="OnBack"/>
      <Button x:Name="nextButton"
              Content="Next"
              Width="90"
              Height="28"
              Margin="0,0,10,0"
              Click="OnNext"/>
      <Button x:Name="generateButton"
              Content="Generate"
              Width="90"
              Height="28"
              Margin="0,0,10,0"
              Click="OnGenerate"/>
      <Button Content="Cancel"
              Width="90"
              Height="28"
              Click="OnCancel"/>
    </StackPanel>
  </Grid>
</Window>
